; Copy these lines into your backend/.env

; --- Local dev: save every outbound email to a file (no real inbox needed) ---
MAIL_LOG=1

; From header (use your real Gmail when using Gmail SMTP below)
MAIL_FROM=youraddress@gmail.com

; --- Real email (Gmail example; use an App Password, not your normal password) ---
; No Composer required — BlueMart sends via built-in SMTP when vendor/ is absent.
; Optional: run "composer install" in backend for PHPMailer instead.
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=youraddress@gmail.com
MAIL_SMTP_PASS=your_gmail_app_password
MAIL_SMTP_SECURE=tls

; If TLS handshake fails on Windows (certificate errors), try:
; MAIL_SMTP_VERIFY_PEER=0

; Optional: set to 0 if your host uses non-TLS SMTP (uncommon)
; MAIL_SMTP_AUTO_TLS=1
